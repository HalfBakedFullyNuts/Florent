{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit:*)",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npm run lint 1>&2 && npm run build 1>&2 || exit 2",
            "timeout": 180,
            "statusMessage": "Running lint + build before commit"
          }
        ]
      }
    ]
  }
}
